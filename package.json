{
  "name": "lpviz",
  "private": true,
  "version": "1.1.0",
  "type": "module",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "vite --port 3000",
    "build": "vite build",
    "preview": "vite preview --port 3000",
    "test": "bun test",
    "format": "prettier --write --print-width 3000 apps packages package.json tsconfig.base.json tsconfig.json vite.config.ts index.html && bunx tsc --noEmit && bunx knip",
    "deploy": "npx wrangler deploy --assets=./dist --name lpviz --compatibility-date 2025-09-01",
    "prdeploy": "npx wrangler versions upload --assets=./dist --name lpviz --compatibility-date 2025-09-01"
  },
  "devDependencies": {
    "@types/bun": "^1.3.14",
    "@types/three": "^0.181.0",
    "playwright": "^1.58.2",
    "prettier": "^3.6.2",
    "typescript": "^5.9.3",
    "vite": "^8.0.8"
  },
  "dependencies": {
    "@lpviz/math": "workspace:*",
    "@lpviz/polytope": "workspace:*",
    "@lpviz/solver-engine": "workspace:*",
    "@lpviz/viewport": "workspace:*",
    "jsoncrush": "^1.1.8",
    "three": "^0.181.1",
    "wrangler": "^4.47.0"
  },
  "knip": {
    "workspaces": {
      ".": {
        "project": [
          "scripts/**/*.mjs"
        ]
      },
      "apps/web": {
        "project": [
          "src/**/*.ts"
        ]
      },
      "packages/math": {
        "project": [
          "src/**/*.ts"
        ]
      },
      "packages/polytope": {
        "project": [
          "src/**/*.ts"
        ]
      },
      "packages/solver-engine": {
        "project": [
          "src/**/*.ts"
        ]
      },
      "packages/viewport": {
        "project": [
          "src/**/*.ts"
        ]
      }
    }
  }
}
